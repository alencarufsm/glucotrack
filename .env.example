# Copie este arquivo para .env e preencha com seus valores reais do Supabase.
# O arquivo .env NUNCA deve ser enviado ao GitHub (já está no .gitignore).

# Settings > Database > Connection string > URI (substitua [YOUR-PASSWORD] pela senha do banco)
SUPABASE_DB_URL=jdbc:postgresql://db.XXXX.supabase.co:5432/postgres

# Senha do banco que você definiu ao criar o projeto Supabase
SUPABASE_DB_PASSWORD=sua-senha-aqui

# Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui

# Settings > API > Project URL
SUPABASE_URL=https://XXXX.supabase.co

# Settings > API > anon public (usada no Flutter e Angular)
SUPABASE_ANON_KEY=eyJ...sua-chave-anon-aqui
